{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request",
        "initialSamplingPercentage": 5.0
      }
    },
    "logLevel": {
      "default": "Information",
      "Microsoft": "Warning",
      "Function": "Information",
      "Host.Aggregator": "Information"
    }
  }
}
